# === MercadoPago ===
# Access Token de la app de MP para ESG (obtener de https://www.mercadopago.com.ar/developers/panel/app)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx

# === URL base del proyecto en Vercel ===
BASE_URL=https://tu-proyecto.vercel.app

# === Resend (envío de emails) ===
# API Key (obtener de https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxx
# Email remitente (usar onboarding@resend.dev para pruebas, o tu dominio verificado)
EMAIL_FROM=Experiencia Sin Gluten <onboarding@resend.dev>

# === Notificaciones ===
# Emails que reciben la notificación de cada compra (separados por coma)
NOTIFICATION_EMAILS=hola@aletemporini.com

# === URLs de redirección post-pago (páginas en FlexiFunnels) ===
SUCCESS_URL=https://ventas.flexifunnels.com/esg-gracias
FAILURE_URL=https://ventas.flexifunnels.com/esg-error
PENDING_URL=https://ventas.flexifunnels.com/esg-pendiente

# === Google Sheet (registro de pagos) ===
# URL del Google Apps Script deployado como Web App
GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/xxxxxxxxxxxx/exec
